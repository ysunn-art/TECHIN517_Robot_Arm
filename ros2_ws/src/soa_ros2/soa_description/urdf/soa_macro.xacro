<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="soa" params="prefix">

    <xacro:property name="effort_limit" value="10.0"/>
    <xacro:property name="velocity_limit" value="10.0"/>
    <xacro:property name="joint_damping" value="0.1"/>
    <xacro:property name="joint_friction" value="0.1"/>

    <material name="${prefix}yellow">
      <color rgba="1.0 1.0 0.0 1.0"/>
    </material>

    <!-- ========== LINKS ========== -->

    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="0.0137179 -5.19711e-05 0.0334843" rpy="0 0 0"/>
        <mass value="0.147"/>
        <inertia ixx="0.000114686" ixy="-4.59787e-07" ixz="4.97151e-06"
                 iyy="0.000136117" iyz="9.75275e-08" izz="0.000130364"/>
      </inertial>
      <visual>
        <origin xyz="-0.00636471 -9.94414e-05 -0.0024" rpy="1.5708 -1.67685e-15 1.5708"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/base_motor_holder.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-0.00636471 -9.94414e-05 -0.0024" rpy="1.5708 -1.67685e-15 1.5708"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/base_motor_holder.stl"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="-0.00636471 -8.97657e-09 -0.0024" rpy="1.5708 -2.78073e-29 1.5708"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/base.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-0.00636471 -8.97657e-09 -0.0024" rpy="1.5708 -2.78073e-29 1.5708"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/base.stl"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="0.0263353 -8.97657e-09 0.0437" rpy="-8.21148e-16 7.84513e-18 1.249e-15"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="0.0263353 -8.97657e-09 0.0437" rpy="-8.21148e-16 7.84513e-18 1.249e-15"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a.stl"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="-0.0309827 -0.000199441 0.0474" rpy="1.5708 -1.35493e-14 1.5708"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/waveshare_mounting_plate.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-0.0309827 -0.000199441 0.0474" rpy="1.5708 -1.35493e-14 1.5708"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/waveshare_mounting_plate.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}shoulder_link">
      <inertial>
        <origin xyz="-0.0307604 -1.66727e-05 -0.0252713" rpy="0 0 0"/>
        <mass value="0.100006"/>
        <inertia ixx="8.3759e-05" ixy="7.55525e-08" ixz="-1.16342e-06"
                 iyy="8.10403e-05" iyz="1.54663e-07" izz="2.39783e-05"/>
      </inertial>
      <visual>
        <origin xyz="-0.0303992 0.000422241 -0.0417" rpy="1.5708 1.5708 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-0.0303992 0.000422241 -0.0417" rpy="1.5708 1.5708 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a.stl"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="-0.0675992 -0.000177759 0.0158499" rpy="1.5708 -1.5708 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/motor_holder_base.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-0.0675992 -0.000177759 0.0158499" rpy="1.5708 -1.5708 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/motor_holder_base.stl"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="0.0122008 2.22413e-05 0.0464" rpy="-1.5708 2.35221e-33 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/rotation_pitch.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="0.0122008 2.22413e-05 0.0464" rpy="-1.5708 2.35221e-33 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/rotation_pitch.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}upper_arm_link">
      <inertial>
        <origin xyz="-0.0898471 -0.00838224 0.0184089" rpy="0 0 0"/>
        <mass value="0.103"/>
        <inertia ixx="4.08002e-05" ixy="-1.97819e-05" ixz="-4.03016e-08"
                 iyy="0.000147318" iyz="8.97326e-09" izz="0.000142487"/>
      </inertial>
      <visual>
        <origin xyz="-0.11257 -0.0155 0.0187" rpy="-3.14159 -5.27356e-16 -1.5708"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-0.11257 -0.0155 0.0187" rpy="-3.14159 -5.27356e-16 -1.5708"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a.stl"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="-0.065085 0.012 0.0182" rpy="3.14159 -0 -1.30911e-30"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/upper_arm.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-0.065085 0.012 0.0182" rpy="3.14159 -0 -1.30911e-30"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/upper_arm.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}lower_arm_link">
      <inertial>
        <origin xyz="-0.0980701 0.00324376 0.0182831" rpy="0 0 0"/>
        <mass value="0.104"/>
        <inertia ixx="2.87438e-05" ixy="7.41152e-06" ixz="1.26409e-06"
                 iyy="0.000159844" iyz="-4.90188e-08" izz="0.00014529"/>
      </inertial>
      <visual>
        <origin xyz="-0.0648499 -0.032 0.0182" rpy="3.14159 -0 6.67202e-31"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/under_arm.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-0.0648499 -0.032 0.0182" rpy="3.14159 -0 6.67202e-31"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/under_arm.stl"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="-0.0648499 -0.032 0.018" rpy="-3.14159 -2.55351e-15 -1.83387e-30"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/motor_holder_wrist.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-0.0648499 -0.032 0.018" rpy="-3.14159 -2.55351e-15 -1.83387e-30"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/motor_holder_wrist.stl"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="-0.1224 0.0052 0.0187" rpy="-3.14159 -7.88861e-31 -3.14159"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-0.1224 0.0052 0.0187" rpy="-3.14159 -7.88861e-31 -3.14159"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}wrist_link">
      <inertial>
        <origin xyz="-0.000103312 -0.0386143 0.0281156" rpy="0 0 0"/>
        <mass value="0.079"/>
        <inertia ixx="3.68263e-05" ixy="1.7893e-08" ixz="-5.28128e-08"
                 iyy="2.5391e-05" iyz="3.6412e-06" izz="2.1e-05"/>
      </inertial>
      <visual>
        <origin xyz="8.32667e-17 -0.0424 0.0306" rpy="1.5708 1.5708 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a_no_horn.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="8.32667e-17 -0.0424 0.0306" rpy="1.5708 1.5708 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a_no_horn.stl"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="0 -0.028 0.0181" rpy="-1.5708 -1.5708 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/wrist_roll_pitch.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="0 -0.028 0.0181" rpy="-1.5708 -1.5708 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/wrist_roll_pitch.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}gripper_link">
      <inertial>
        <origin xyz="0.000213627 0.000245138 -0.025187" rpy="0 0 0"/>
        <mass value="0.087"/>
        <inertia ixx="2.75087e-05" ixy="-3.35241e-07" ixz="-5.7352e-06"
                 iyy="4.33657e-05" iyz="-5.17847e-08" izz="3.45059e-05"/>
      </inertial>
      <visual>
        <origin xyz="0.0077 0.0001 -0.0234" rpy="-1.5708 -5.19179e-17 -1.66533e-16"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="0.0077 0.0001 -0.0234" rpy="-1.5708 -5.19179e-17 -1.66533e-16"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/sts3215_03a.stl"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="8.32667e-17 -0.000218214 0.000949706" rpy="-3.14159 -5.55112e-17 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/wrist_roll_follower.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="8.32667e-17 -0.000218214 0.000949706" rpy="-3.14159 -5.55112e-17 0"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/wrist_roll_follower.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}gripper_frame_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1e-9"/>
        <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
      </inertial>
    </link>

    <link name="${prefix}moving_jaw_link">
      <inertial>
        <origin xyz="-0.00157495 -0.0300244 0.0192755" rpy="0 0 0"/>
        <mass value="0.012"/>
        <inertia ixx="6.61427e-06" ixy="-3.19807e-07" ixz="-5.90717e-09"
                 iyy="1.89032e-06" iyz="-1.09945e-07" izz="5.28738e-06"/>
      </inertial>
      <visual>
        <origin xyz="-5.55112e-17 -5.55112e-17 0.0189" rpy="9.53145e-17 6.93889e-18 1.24077e-24"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/moving_jaw.stl"/>
        </geometry>
        <material name="${prefix}yellow"/>
      </visual>
      <collision>
        <origin xyz="-5.55112e-17 -5.55112e-17 0.0189" rpy="9.53145e-17 6.93889e-18 1.24077e-24"/>
        <geometry>
          <mesh filename="package://soa_description/meshes/moving_jaw.stl"/>
        </geometry>
      </collision>
    </link>

    <!-- ========== JOINTS ========== -->

    <joint name="${prefix}shoulder_pan" type="revolute">
      <origin xyz="0.0388353 -8.97657e-09 0.0624" rpy="3.14159 4.18253e-17 -3.14159"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}shoulder_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="${effort_limit}" velocity="${velocity_limit}" lower="-2.04786" upper="2.04786"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <joint name="${prefix}shoulder_lift" type="revolute">
      <origin xyz="-0.0303992 -0.0182778 -0.0542" rpy="-1.5708 -1.5708 0"/>
      <parent link="${prefix}shoulder_link"/>
      <child link="${prefix}upper_arm_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="${effort_limit}" velocity="${velocity_limit}" lower="-1.89089" upper="1.89089"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <joint name="${prefix}elbow_flex" type="revolute">
      <origin xyz="-0.11257 -0.028 1.73763e-16" rpy="-3.63608e-16 8.74301e-16 1.5708"/>
      <parent link="${prefix}upper_arm_link"/>
      <child link="${prefix}lower_arm_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="${effort_limit}" velocity="${velocity_limit}" lower="-1.69021" upper="1.69021"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <joint name="${prefix}wrist_flex" type="revolute">
      <origin xyz="-0.1349 0.0052 3.62355e-17" rpy="4.02456e-15 8.67362e-16 -1.5708"/>
      <parent link="${prefix}lower_arm_link"/>
      <child link="${prefix}wrist_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="${effort_limit}" velocity="${velocity_limit}" lower="-1.78913" upper="1.78913"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <joint name="${prefix}wrist_roll" type="revolute">
      <origin xyz="5.55112e-17 -0.0611 0.0181" rpy="1.5708 0.0486795 3.14159"/>
      <parent link="${prefix}wrist_link"/>
      <child link="${prefix}gripper_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="${effort_limit}" velocity="${velocity_limit}" lower="-2.99306" upper="2.99306"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <joint name="${prefix}gripper" type="revolute">
      <origin xyz="0.0202 0.0188 -0.0234" rpy="1.5708 -5.24284e-08 -1.41553e-15"/>
      <parent link="${prefix}gripper_link"/>
      <child link="${prefix}moving_jaw_link"/>
      <axis xyz="0 0 1"/>
      <limit effort="${effort_limit}" velocity="${velocity_limit}" lower="-0.28839" upper="1.85050"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <joint name="${prefix}gripper_frame_joint" type="fixed">
      <origin xyz="-0.0079 -0.000218121 -0.0981274" rpy="0 3.14159 0"/>
      <parent link="${prefix}gripper_link"/>
      <child link="${prefix}gripper_frame_link"/>
    </joint>

  </xacro:macro>

</robot>
